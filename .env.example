# Server
PORT=4000
NODE_ENV=development
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
# Set false to block *.vercel.app preview URLs in production
CORS_ALLOW_VERCEL=true

# Admin
ADMIN_API_KEY=change-me-in-production

# Founding cohort — free programs before public pricing (match frontend flag)
FOUNDING_FREE=true

# Razorpay (mock when unset; ignored when FOUNDING_FREE=true)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Database — pick one for production
DATABASE_URL=
BLOB_READ_WRITE_TOKEN=

# Google Sheets (optional)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
